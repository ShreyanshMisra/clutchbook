# Optional: override the Lichess API base (used by the Python backend).
# LICHESS_BASE=https://lichess.org/api

# Frontend: in local dev the Vite proxy sends /api -> http://localhost:8000.
# In production on Vercel, /api is same-origin (no value needed).
# Set this only if you host the backend somewhere other than same-origin.
# VITE_API_BASE=

# FaceIt Data API key (https://developers.faceit.com). Required for the CS2 adapter.
FACEIT_API_KEY=
